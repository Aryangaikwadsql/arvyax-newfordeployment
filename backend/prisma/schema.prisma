// This is your Prisma schema file,
// learn more about it in the docs: https://prisma.io/docs/reference/api-reference/prisma-schema-reference

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Entry {
  id        Int      @id @default(autoincrement())
  userId    String
  ambience  String
  text      String
  emotion   String?
  keywords  String?
  summary   String?
  createdAt DateTime @default(now())

  @@map("entries")
}
